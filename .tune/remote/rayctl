# Control Ray cluster
# Usage: rayctl <workdir> <action>

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TUNE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

. "$TUNE_ROOT/lib/config_load.sh"

WORKDIR="$1"
ACTION="$2"

if [ -z "$WORKDIR" ] || [ -z "$ACTION" ]; then
    echo "Usage: $0 <workdir> <action>" >&2
    echo "Actions: start|stop|status" >&2
    exit 1
fi

load_config_container "$WORKDIR"

# Derive ray binary path from CELERY_WORKER_PYTHON
if [ -z "$CELERY_WORKER_PYTHON" ]; then
    echo "Error: CELERY_WORKER_PYTHON not set in config.rc" >&2
    exit 1
fi
RAY_BIN="$(dirname "$CELERY_WORKER_PYTHON")/ray"

if [ ! -x "$RAY_BIN" ]; then
    echo "Error: Ray not found at $RAY_BIN" >&2
    exit 1
fi

# Ray temp directory
RAY_TMPDIR="$WORKDIR/run/ray"
mkdir -p "$RAY_TMPDIR"

case "$ACTION" in
    start)
        echo "Starting Ray cluster..."
        # Auto-detect GPU count if not specified
        if [ -z "$NUM_GPUS" ]; then
            NUM_GPUS=$(rocm_agent_enumerator | grep -v gfx000 | wc -l)
            echo "Auto-detected $NUM_GPUS GPUs"
        fi

        "$RAY_BIN" start --head \
            --node-ip-address=127.0.0.1 \
            --num-gpus="$NUM_GPUS" \
            --temp-dir="$RAY_TMPDIR" \
            --include-dashboard=false \
            --disable-usage-stats

        echo "Ray cluster started with $NUM_GPUS GPUs"
        ;;
    stop)
        echo "Stopping Ray cluster..."
        "$RAY_BIN" stop
        echo "Ray cluster stopped"
        ;;
    status)
        "$RAY_BIN" status || echo "Ray cluster not running"
        ;;
    *)
        echo "Unknown action: $ACTION" >&2
        exit 1
        ;;
esac
