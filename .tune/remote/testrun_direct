# Run the testrun CLI tool inside the tuning Docker image.
#
# This script is meant to be invoked as:
#   <workdir>/aotriton.src/.tune/remote/testrun_direct [args...]
#
# The workdir is detected automatically from the script's location:
#   testrun_direct lives at  <workdir>/aotriton.src/.tune/remote/testrun_direct
#   so workdir is            <workdir>/aotriton.src/../.. resolved
#
# Docker image and connection parameters are read from <workdir>/config.rc.
# The container is removed automatically on exit (--rm).
#
# All arguments are forwarded verbatim to:
#   python -m v3python.tune.testrun [args...]
#
# Examples:
#   # Show testrun help
#   .tune/remote/testrun_direct -h
#   .tune/remote/testrun_direct --help
#
#   # Run a specific entry on gfx942
#   .tune/remote/testrun_direct arch=gfx942 dtype='float16';hdim=128;...
#
#   # Dry-run / list kernels
#   .tune/remote/testrun_direct --list arch=gfx942 dtype='float16';hdim=128;...

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AOTRITON_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
WORKDIR="$(cd "$AOTRITON_ROOT/.." && pwd)"

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    cat <<EOF
Usage: $(basename "$0") [testrun args...]

Run the v3python.tune.testrun CLI inside the tuning Docker image.

Workdir auto-detected from script location:
  $WORKDIR

Config read from:
  $WORKDIR/config.rc

The container is ephemeral (--rm) and interactive.
All arguments are forwarded to:
  python -m v3python.tune.testrun [testrun args...]

To see testrun's own help, run without arguments or pass --help after
the testrun module has loaded (some flags may differ from this wrapper).

Examples:
  # Show testrun module help
  $(basename "$0")

  # Run a specific entry
  $(basename "$0") arch=gfx942 "dtype='float16';hdim=128;seqlen_q=4096;seqlen_k=4096;causal=False;dropout_p=0.0;bias_type=0"
EOF
    exit 0
fi

if [ ! -f "$WORKDIR/config.rc" ]; then
    echo "Error: config.rc not found at $WORKDIR/config.rc" >&2
    exit 1
fi

. "$WORKDIR/config.rc"

if [ -z "${CELERY_WORKER_IMAGE:-}" ]; then
    echo "Error: CELERY_WORKER_IMAGE not set in config.rc" >&2
    exit 1
fi

# Extract arch from args (e.g. "arch=gfx942 ..." or "arch=gfx942;...").
# Fall back to rocm_agent_enumerator when not found in args.
# PYTHONPATH must point to the arch-specific installed libs inside the container.
ARCH=""
for arg in "$@"; do
    if [[ "$arg" =~ ^arch=([^;[:space:]]+) ]]; then
        ARCH="${BASH_REMATCH[1]}"
        break
    fi
done

if [ -z "$ARCH" ]; then
    ARCH=$(rocm_agent_enumerator | grep -v gfx000 | head -1)
fi

if [ -z "$ARCH" ]; then
    echo "Error: could not detect arch from args or rocm_agent_enumerator" >&2
    exit 1
fi

exec docker run --rm -it \
    --device=/dev/kfd \
    --device=/dev/dri \
    --group-add video \
    --cap-add=SYS_PTRACE \
    --security-opt seccomp=unconfined \
    --ipc=host \
    --network=host \
    -e "PYTHONPATH=/wkdir/installed/$ARCH/lib" \
    -e PYTHONPYCACHEPREFIX=/wkdir/run/pycache \
    --mount type=bind,source="$(realpath "$WORKDIR")",target=/wkdir \
    "$CELERY_WORKER_IMAGE" \
    bash -l -c '
        source /wkdir/config.rc
        source "$(dirname "$CELERY_WORKER_PYTHON")/activate"
        cd /wkdir/aotriton.src
        exec "$CELERY_WORKER_PYTHON" -m v3python.tune.testrun "$@"
    ' -- "$@"
