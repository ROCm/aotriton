# Run the testrun CLI tool inside the tuning Docker image.
#
# Interface is identical to v3python.tune.testrun:
#   testrun_direct [module] [--gpu GPU]
#
# The workdir is detected automatically from the script's location:
#   testrun_direct lives at  <workdir>/aotriton.src/.tune/remote/testrun_direct
#   so workdir is            <workdir>/aotriton.src/../.. resolved
#
# Docker image and connection parameters are read from <workdir>/config.rc.
# The container is removed automatically on exit (--rm).
#
# GPU architecture is detected automatically via rocm_agent_enumerator.
#
# PYTHONPATH selection (based on module name):
#   Modules ending with _op use the testing library: installed/test/<arch>/lib
#   All other modules use the tuning library:        installed/<arch>/lib
#
# testrun is a REPL — commands are sent via stdin, not positional arguments.
#
# Examples:
#   # Show this wrapper's help
#   .tune/remote/testrun_direct -h
#   .tune/remote/testrun_direct --help
#
#   # Interactive session for kernel tuning
#   .tune/remote/testrun_direct flash
#
#   # Interactive session for op tuning (uses installed/test/ PYTHONPATH)
#   .tune/remote/testrun_direct flash_op
#
#   # Run a specific entry non-interactively (pipe commands via stdin)
#   printf 'prepare_data dtype=float16;hdim=128;seqlen_q=4096;seqlen_k=4096;causal=False;dropout_p=0.0;bias_type=0 /tmp/myentry\n' \
#     | .tune/remote/testrun_direct flash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AOTRITON_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
WORKDIR="$(cd "$AOTRITON_ROOT/.." && pwd)"

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    cat <<EOF
Usage: $(basename "$0") [module] [--gpu GPU]

Run the v3python.tune.testrun REPL inside the tuning Docker image.
Interface is identical to: python -m v3python.tune.testrun

GPU architecture is auto-detected via rocm_agent_enumerator.

PYTHONPATH selection (based on module name):
  Modules ending with _op  → installed/test/<arch>/lib  (testing library)
  All other modules        → installed/<arch>/lib        (tuning library)

Workdir auto-detected from script location:
  $WORKDIR

Config read from:
  $WORKDIR/config.rc

testrun is a REPL: commands are read from stdin, not passed as positional args.
Pipe commands in for non-interactive use.

Examples:
  # Interactive session
  $(basename "$0") flash

  # Interactive session for op tuning
  $(basename "$0") flash_op

  # Run a specific entry non-interactively
  printf 'prepare_data dtype=float16;hdim=128;seqlen_q=4096;seqlen_k=4096;causal=False;dropout_p=0.0;bias_type=0 /tmp/myentry\n' \\
    | $(basename "$0") flash
EOF
    exit 0
fi

if [ ! -f "$WORKDIR/config.rc" ]; then
    echo "Error: config.rc not found at $WORKDIR/config.rc" >&2
    exit 1
fi

. "$WORKDIR/config.rc"

if [ -z "${CELERY_WORKER_IMAGE:-}" ]; then
    echo "Error: CELERY_WORKER_IMAGE not set in config.rc" >&2
    exit 1
fi

# Detect arch from rocm_agent_enumerator.
ARCH=$(rocm_agent_enumerator | grep -v gfx000 | head -1)
if [ -z "$ARCH" ]; then
    echo "Error: could not detect arch via rocm_agent_enumerator" >&2
    exit 1
fi

# Peek at the module positional arg (first non-option arg) for PYTHONPATH selection.
# All args are passed verbatim to testrun — nothing is consumed here.
MODULE=""
skip_next=false
for arg in "$@"; do
    if $skip_next; then
        skip_next=false
        continue
    fi
    case "$arg" in
        --gpu) skip_next=true ;;
        --*)   ;;
        *)     MODULE="$arg"; break ;;
    esac
done

# Modules ending with _op use the testing library (no KernelControl).
if [[ "$MODULE" == *_op ]]; then
    WORKER_PYTHONPATH="/wkdir/installed/test/$ARCH/lib"
else
    WORKER_PYTHONPATH="/wkdir/installed/$ARCH/lib"
fi

exec docker run --rm -it \
    --device=/dev/kfd \
    --device=/dev/dri \
    --group-add video \
    --cap-add=SYS_PTRACE \
    --security-opt seccomp=unconfined \
    --ipc=host \
    --network=host \
    -e "PYTHONPATH=$WORKER_PYTHONPATH" \
    -e PYTHONPYCACHEPREFIX=/wkdir/run/pycache \
    --mount type=bind,source="$(realpath "$WORKDIR")",target=/wkdir \
    "$CELERY_WORKER_IMAGE" \
    bash -l -c '
        source /wkdir/config.rc
        source "$(dirname "$CELERY_WORKER_PYTHON")/activate"
        cd /wkdir/aotriton.src
        exec "$CELERY_WORKER_PYTHON" -m v3python.tune.testrun "$@"
    ' -- "$@"
