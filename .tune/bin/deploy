#!/bin/bash
# Copyright © 2026 Advanced Micro Devices, Inc.
# SPDX-License-Identifier: MIT

# Deploy workdir to all workers
# Usage: deploy <workdir> [--tuning_mode kernel|op]
#
# --tuning_mode kernel (default)  Deploy to Tuner-role hosts; sync installed/<arch>/.
# --tuning_mode op                Deploy to Tuner-role hosts; sync installed/test/<arch>/.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TUNE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

. "$TUNE_ROOT/lib/config_load.sh"
. "$TUNE_ROOT/lib/db_query.sh"

WORKDIR="$1"
shift

TUNING_MODE="kernel"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --tuning_mode) TUNING_MODE="$2"; shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

if [ -z "$WORKDIR" ]; then
    echo "Usage: $0 <workdir> [--tuning_mode kernel|op]" >&2
    exit 1
fi

load_config "$WORKDIR"

echo "Deploying from $WORKDIR (tuning_mode=$TUNING_MODE)"

if [ "$TUNING_MODE" = "op" ]; then
    SYNC_FLAG="--testnode"
else
    SYNC_FLAG=""
fi
mapfile -t WORKER_DATA < <(get_workers "$WORKDIR" Tuner)

for worker in "${WORKER_DATA[@]}"; do
    IFS='|' read -r hostname arch workdir_override <<< "$worker"
    WORKER_WORKDIR="${workdir_override:-$DEFAULT_WORKDIR}"

    echo "Deploying to $hostname ($arch) at $WORKER_WORKDIR"

    "$TUNE_ROOT/single/sync_workdir.sh" "$WORKDIR" "$hostname" $SYNC_FLAG
done

# SLURM deployment if configured
if [ -n "$SLURM_LOGIN_NODE" ]; then
    echo "Deploying to SLURM: $SLURM_LOGIN_NODE at $SLURM_WORKER_DIR"

    "$TUNE_ROOT/single/sync_workdir.sh" "$WORKDIR" "$SLURM_LOGIN_NODE" $SYNC_FLAG
fi

echo "Deployment complete"
