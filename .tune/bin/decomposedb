#!/bin/bash
# Copyright © 2026 Advanced Micro Devices, Inc.
# SPDX-License-Identifier: MIT

# Decompose the centralized SQLite database into per-arch/kernel shards.
#
#   1. Generate scratch/decompose_db.sh from scratch/centraldb.sqlite3
#      via aotriton.database_decompose
#   2. Execute the generated script to produce
#      <workdir>/installed/database/amd/<arch>/<family>/<kernel>.sqlite3.tar.xz
#
# Usage:
#   decomposedb <workdir> [--tuning_mode kernel|op]

set -euo pipefail

if [ "$#" -lt 1 ]; then
    echo "Usage: $0 <workdir> [--tuning_mode kernel|op]" >&2
    exit 1
fi

WORKDIR="$1"
shift

TUNING_MODE="kernel"
while [ "$#" -gt 0 ]; do
    case "$1" in
        --tuning_mode) TUNING_MODE="$2"; shift 2 ;;
        *) echo "Unknown argument: $1" >&2; exit 1 ;;
    esac
done

if [ ! -d "$WORKDIR" ]; then
    echo "Error: workdir does not exist: $WORKDIR" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
. "$SCRIPT_DIR/../lib/require_aotriton_pkg.sh"

DECOMPOSE_OUTPUT="$WORKDIR/installed/database"
mkdir -p "$DECOMPOSE_OUTPUT"

if [ "$TUNING_MODE" = "op" ]; then
    OP_DB="$WORKDIR/scratch/op_database.sqlite3"
    if [ ! -f "$OP_DB" ]; then
        echo "Error: op_database.sqlite3 not found: $OP_DB" >&2
        echo "Run export_best_results --tuning_mode op first." >&2
        exit 1
    fi

    echo "Vacuuming op_database.sqlite3..."
    sqlite3 "$OP_DB" "VACUUM;"

    echo "Compressing op_database.sqlite3..."
    tar -cJf "$DECOMPOSE_OUTPUT/op_database.sqlite3.tar.xz" \
        -C "$(dirname "$OP_DB")" "$(basename "$OP_DB")"
    echo "Decompose (op) complete: $DECOMPOSE_OUTPUT/op_database.sqlite3.tar.xz"
    exit 0
fi

CENTRALDB="$WORKDIR/scratch/centraldb.sqlite3"

if [ ! -f "$CENTRALDB" ]; then
    echo "Error: centraldb.sqlite3 not found: $CENTRALDB" >&2
    echo "Run export_best_results first." >&2
    exit 1
fi

GNU_PARALLEL=$(which parallel 2>/dev/null || true)
if [ -z "$GNU_PARALLEL" ] || ! "$GNU_PARALLEL" --version 2>/dev/null | grep -q 'GNU parallel'; then
    echo "Error: GNU parallel is required but not installed (found moreutils parallel or nothing)." >&2
    echo "Install: sudo apt-get install parallel  OR  conda install -c conda-forge parallel" >&2
    exit 1
fi
export GNU_PARALLEL

SCRIPT_OUTPUT="$WORKDIR/scratch/decompose_db.sh"

rm -rf "$DECOMPOSE_OUTPUT"
mkdir -p "$DECOMPOSE_OUTPUT"

echo "Step 1/3: Generating decompose script..."
echo "  Input:  $CENTRALDB"
echo "  Script: $SCRIPT_OUTPUT"
echo "  Output: $DECOMPOSE_OUTPUT"

PYTHONPATH="$REPO_ROOT" python3 -m aotriton.database_decompose \
    --database_file "$CENTRALDB" \
    --script_output "$SCRIPT_OUTPUT" \
    --decompose_output "$DECOMPOSE_OUTPUT"

echo ""
echo "Step 2/3: Running decompose script..."
bash "$SCRIPT_OUTPUT"

echo ""
echo "Step 3/3: Copying base database archives from modules/database/..."
cp "$REPO_ROOT"/modules/database/*.sqlite3.tar.xz "$DECOMPOSE_OUTPUT/"

echo ""
echo "Decompose complete: $DECOMPOSE_OUTPUT"
