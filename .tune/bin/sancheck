#!/bin/bash
# Copyright © 2026 Advanced Micro Devices, Inc.
# SPDX-License-Identifier: MIT

# Run the LUT sanity check against a centralized tuning database without
# triggering any code generation.
#
# Usage:
#   sancheck <workdir> [extra generate.py args...]
#
# The tuning database is expected at:
#   <workdir>/scratch/centraldb.sqlite3
#
# This is the file produced by .tune/bin/export_best_results.
#
# GPU targets are read from <workdir>/config.rc (SANCHECK_GPUS variable) if
# present, otherwise all supported GPUs are used.
#
# Extra arguments are passed directly to generate.py.
#
# Examples:
#   .tune/bin/sancheck ~/wkdir.v3.5
#   .tune/bin/sancheck ~/wkdir.v3.5 --target_gpus gfx942_mod0 gfx90a_mod0

set -euo pipefail

if [ "$#" -lt 1 ]; then
    echo "Usage: $0 <workdir> [--tuning_mode kernel|op] [extra generate.py args...]" >&2
    exit 1
fi

WORKDIR="$1"
shift
TUNING_MODE="kernel"
EXTRA_ARGS=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        --tuning_mode) TUNING_MODE="$2"; shift 2 ;;
        *) EXTRA_ARGS+=("$1"); shift ;;
    esac
done

if [ ! -d "$WORKDIR" ]; then
    echo "Error: workdir does not exist: $WORKDIR" >&2
    exit 1
fi

CENTRALDB="$WORKDIR/scratch/centraldb.sqlite3"
if [ ! -f "$CENTRALDB" ]; then
    echo "Error: tuning database not found: $CENTRALDB" >&2
    echo "Run .tune/bin/export_best_results first." >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
. "$SCRIPT_DIR/../lib/require_aotriton_pkg.sh"

# Derive GPU targets from the gpu column in the centralized database.
# This avoids any config.rc dependency — the database already knows
# which GPUs have been tuned.
GPUS=$(sqlite3 "$CENTRALDB" \
    "SELECT DISTINCT gpu FROM \"FLASH\$attn_fwd\" \
     UNION SELECT gpu FROM \"FLASH\$bwd_kernel_dk_dv\" \
     UNION SELECT gpu FROM \"FLASH\$bwd_kernel_dq\" \
     UNION SELECT gpu FROM \"FLASH\$bwd_kernel_fuse\"" \
    2>/dev/null | tr '\n' ' ' | xargs)

GPU_ARGS=()
if [ -n "$GPUS" ]; then
    read -ra GPU_ARGS <<< "--target_gpus $GPUS"
fi

# Persistent build directory.
#   <workdir>/build/sancheck/database/tuning_database.sqlite3  (symlink)
#   <workdir>/build/sancheck/database/op_database.sqlite3      (op mode only; kernel mode
#     falls back to modules/database/'s checked-in baseline via python/database/sqlite.py)
TMPDIR_BUILD="$WORKDIR/build/sancheck"
mkdir -p "$TMPDIR_BUILD/database"

# tuning_database.sqlite3: always re-symlink in case the path changed.
ln -sf "$(realpath "$CENTRALDB")" "$TMPDIR_BUILD/database/tuning_database.sqlite3"

# op_database.sqlite3: only stage a fresh copy in op mode (this takes
# precedence over the checked-in baseline). Kernel mode needs nothing here.
if [ "$TUNING_MODE" = "op" ]; then
    cp "$WORKDIR/scratch/op_database.sqlite3" "$TMPDIR_BUILD/database/op_database.sqlite3"
fi

REPORT="$WORKDIR/scratch/dbreport.txt"
mkdir -p "$WORKDIR/scratch"
echo "Sanity check report: $REPORT"

# generate.py has no --tuning_mode concept of its own: without --selective it
# walks every family/codegen_module (flash's kernels AND flash_op's operators)
# in one pass. Scope to just the one being checked via unique_path's
# <family>/<codegen_module>/<name> convention.
# TODO: extend when additional families (e.g. gemm) are added.
if [ "$TUNING_MODE" = "op" ]; then
    SELECTIVE_ARGS=(--selective 'flash/op/*')
else
    SELECTIVE_ARGS=(--selective 'flash/triton/*')
fi

# Diagnostic output goes to stdout (bare print() calls, no logging framework).
python3 -m aotriton.generate \
    --build_dir "$TMPDIR_BUILD" \
    --root_dir "$REPO_ROOT" \
    --lut_sanity_check \
    --sanity_check_only \
    "${GPU_ARGS[@]}" \
    "${SELECTIVE_ARGS[@]}" \
    "${EXTRA_ARGS[@]}" > "$REPORT"

echo "Done. Report written to $REPORT"

MISSING=$(grep -c 'TUNE_V3BIS' "$REPORT" 2>/dev/null || true)
echo "Missing LUT entries: $MISSING"

if [ "$MISSING" -gt 0 ]; then
    echo "Error: sancheck found $MISSING missing LUT entries." >&2
    echo "  → Run retry_missing_entries to re-queue missing tasks, then bake_lut --incremental." >&2
    echo "  → (bake_lut --fix is for entries present but failed in correctness tests.)" >&2
    exit 1
fi
