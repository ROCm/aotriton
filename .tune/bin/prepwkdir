# Prepare working directory on dev node
# Usage: prepwkdir <workdir>

if [ -z "$BASH_VERSION" ]; then
  echo "This script requires Bash. Please run it with 'bash script_name.sh' or ensure /bin/sh points to /bin/bash." >&2
  exit 1
fi

if [ "$#" -ne 1 ]; then
  cat >&2 <<EOF
Usage: $0 <workdir>

Prepare working directory on dev node.

Arguments:
  <workdir>  Project working directory (created by initproj)

This script will:
  1. Clone or update AOTriton source to <workdir>/aotriton.src
  2. Copy image.scripts from .tune to <workdir>
  3. Create <workdir>/image.build/Dockerfile
EOF
  exit 1
fi

set -x

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TUNE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
AOTRITON_ROOT="$(realpath "${TUNE_ROOT}/..")"
WORKDIR=$(realpath "$1")

# Validate
if [ ! -d "$WORKDIR" ] || [ ! -f "$WORKDIR/workers.db" ]; then
  echo "Error: Invalid workdir or workers.db not found" >&2
  exit 1
fi

# Step 1: Clone or update AOTriton source
AOTRITON_SRC="$WORKDIR/aotriton.src"

# Get current branch (use -C to avoid cd)
CURRENT_BRANCH=$(git -C "$AOTRITON_ROOT" rev-parse --abbrev-ref HEAD)
if [ -z "$CURRENT_BRANCH" ]; then
  echo "Error: Cannot determine current branch" >&2
  exit 1
fi

# Check if current branch is upstream/main
IS_UPSTREAM_MAIN=false
if [ "$CURRENT_BRANCH" = "main" ] && \
   git -C "$AOTRITON_ROOT" rev-parse --verify upstream/main >/dev/null 2>&1 && \
   [ "$(git -C "$AOTRITON_ROOT" rev-parse HEAD)" = "$(git -C "$AOTRITON_ROOT" rev-parse upstream/main)" ]; then
  IS_UPSTREAM_MAIN=true
  CLONE_DEPTH=3
fi

# If not upstream/main, verify upstream/main is in history
if [ "$IS_UPSTREAM_MAIN" = false ]; then
  if ! git -C "$AOTRITON_ROOT" merge-base --is-ancestor upstream/main HEAD 2>/dev/null; then
    echo "Error: upstream/main is not in current branch's history" >&2
    echo "Current branch: $CURRENT_BRANCH" >&2
    exit 1
  fi
  # Calculate depth from upstream/main to HEAD
  CLONE_DEPTH=$(git -C "$AOTRITON_ROOT" rev-list --count upstream/main..HEAD)
  CLONE_DEPTH=$((CLONE_DEPTH + 1))
fi

# Try to update existing clone or create new one
if [ -d "$AOTRITON_SRC/.git" ]; then
  echo "Updating existing AOTriton source..."
  if ! git -C "$AOTRITON_SRC" pull --rebase origin "$CURRENT_BRANCH" 2>/dev/null; then
    echo "Pull failed (possibly due to rebase), removing and re-cloning..."
    rm -rf "$AOTRITON_SRC"
    NEED_CLONE=true
  else
    NEED_CLONE=false
  fi
else
  NEED_CLONE=true
fi

if [ "$NEED_CLONE" = true ]; then
  echo "Cloning from local repository (branch: $CURRENT_BRANCH, depth: $CLONE_DEPTH)..."
  git clone --depth "$CLONE_DEPTH" --branch "$CURRENT_BRANCH" "file://$AOTRITON_ROOT" "$AOTRITON_SRC"

  if [ $? -ne 0 ]; then
    echo "Error: Failed to clone AOTriton source" >&2
    exit 1
  fi
fi

# Step 2: Sync image.scripts directory
echo "Syncing image.scripts..."
rsync -a "$TUNE_ROOT/image.scripts/" "$WORKDIR/image.scripts/"

# Step 3: Create Dockerfile
echo "Creating Dockerfile..."
bash "$TUNE_ROOT/lib/create_dockerfile.sh" "$WORKDIR"

echo "Working directory preparation completed"
