#!/bin/bash
# Copyright © 2026 Advanced Micro Devices, Inc.
# SPDX-License-Identifier: MIT

# Build worker Docker images
# Usage: imgbld [--host <hostname>...] <workdir>

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TUNE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

. "$TUNE_ROOT/lib/config_load.sh"
. "$TUNE_ROOT/lib/db_query.sh"
. "$TUNE_ROOT/lib/host_filter.sh"

parse_host_filter "$@"

# Remove --host from args
ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --host)
            shift
            while [[ $# -gt 0 ]] && [[ ! "$1" =~ ^-- ]]; do
                shift
            done
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

WORKDIR="${ARGS[0]}"

if [ -z "$WORKDIR" ]; then
    echo "Usage: $0 [--host <hostname>...] <workdir>" >&2
    exit 1
fi

load_config "$WORKDIR"

BUILD_COUNT=0
while IFS= read -r hostname; do
    if ! should_process_host "$hostname"; then
        continue
    fi

    # Determine remote workdir for this worker
    WORKER_INFO=$(get_worker_by_hostname "$WORKDIR" "$hostname")
    IFS='|' read -r arch workdir_override <<< "$WORKER_INFO"
    WORKER_WORKDIR="${workdir_override:-$DEFAULT_WORKDIR}"

    echo "Queuing docker build on $hostname (workdir: $WORKER_WORKDIR)"

    "$TUNE_ROOT/single/build_image.sh" "$WORKDIR" "$hostname"

    BUILD_COUNT=$((BUILD_COUNT + 1))
done < <(get_hostnames "$WORKDIR")

if [ "$BUILD_COUNT" -eq 0 ]; then
    echo "Warning: No workers matched the specified criteria" >&2
    exit 1
fi

echo "Docker build jobs queued on $BUILD_COUNT worker(s). Monitor with: ssh <hostname> tsp"
