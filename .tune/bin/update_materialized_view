# Incrementally update most_accurate_tuning_results for the task_ids listed
# in <workdir>/scratch/retry_task_ids.txt (written by retry_missing_entries).
#
# Usage:
#   update_materialized_view <workdir>

set -euo pipefail

if [ "$#" -lt 1 ]; then
    echo "Usage: $0 <workdir>" >&2
    exit 1
fi

WORKDIR="$1"

if [ ! -d "$WORKDIR" ]; then
    echo "Error: workdir does not exist: $WORKDIR" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TUNE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REPO_ROOT="$(cd "$TUNE_ROOT/.." && pwd)"

TASK_IDS_FILE="$WORKDIR/scratch/retry_task_ids.txt"

if [ ! -f "$TASK_IDS_FILE" ]; then
    echo "Error: task_ids file not found: $TASK_IDS_FILE" >&2
    echo "Run .tune/bin/retry_missing_entries first." >&2
    exit 1
fi

echo "Updating most_accurate_tuning_results (incremental)..."
echo "Task IDs file: $TASK_IDS_FILE"

PYTHONPATH="$REPO_ROOT" python3 -m v3python.tune.pq.populate_most_accurate \
    "$WORKDIR" --task_ids_file "$TASK_IDS_FILE"
